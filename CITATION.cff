    given-names: Sanjay
    affiliation: Waymark
  - name: "Hidden Health Data contributors"
keywords:
  - public health
  - Medicaid
  - dark data
  - external quality review
  - health equity
  - open data
  - document extraction
license: Apache-2.0
version: 0.4.0
date-released: "2026-06-09"
url: "https://github.com/sanjaybasu/dark-health-data"
