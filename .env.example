# Copy to .env and fill in to enable the LLM extractor.
# The offline demo (rule extractor) needs none of this.

# Anthropic API key for the Claude-based structured extractor.
ANTHROPIC_API_KEY=

# Optional: override the extraction model (default: claude-sonnet-4-6).
# For cheaper large runs consider a smaller model.
# OHD_LLM_MODEL=claude-sonnet-4-6
