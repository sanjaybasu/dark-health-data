# Real state MMRC reports (verify URLs before a run; sites reorganize).
# Copy to registry/sources_mmrc.yaml and run with --extractor llm.
# These are the sources used to produce the v0.3.0 real mmrc release.
sources:
  - state: MS
    committee: Mississippi State Department of Health Maternal Mortality Review Committee
    reports:
      - {year: 2025, title: "Mississippi Maternal Mortality Report (Review of 2019-2023)", url: "https://msdh.ms.gov/msdhsite/index.cfm/29,21452,299,pdf/Maternal_Mortality_Report_2025.pdf"}
  - state: US
    committee: Building U.S. Capacity to Review and Prevent Maternal Deaths (CDC Foundation)
    reports:
      - {year: 2018, title: "Report from Nine Maternal Mortality Review Committees", url: "https://www.cdcfoundation.org/sites/default/files/files/ReportfromNineMMRCs.pdf"}
